# Dev playground env. create-nextly-app copies this file to dev/.env for you;
# recreate dev/.env from this example if you ever delete it.
DB_DIALECT=sqlite
DATABASE_URL=file:./nextly-dev.db

# Any non-empty secret works for local dev (sign/verify session cookies).
NEXTLY_SECRET=dev-secret-change-me

NEXT_PUBLIC_SITE_URL=http://localhost:3000
