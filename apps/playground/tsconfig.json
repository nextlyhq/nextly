{
  "extends": "../../packages/tsconfig/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "nextly": ["../../packages/nextly/src"],
      "@nextly/admin": ["../../packages/admin/src"],
      "@admin/*": ["../../packages/admin/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
