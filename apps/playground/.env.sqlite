# SQLite Environment Configuration
# Copy this to .env to use SQLite

NODE_ENV=development
DB_DIALECT=sqlite
DATABASE_URL=file:./data/nextly.db

# Auth Configuration
AUTH_SECRET=your-secret-key-minimum-32-characters-change-in-production-use-openssl-rand
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
