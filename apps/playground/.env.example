# Nextly Playground - Environment Configuration
#
# Default configuration uses SQLite - works out of the box with no
# external services, no Docker. Switch to Postgres or MySQL via the
# dedicated dev scripts (which override DB_DIALECT + DATABASE_URL
# per-process without modifying this file):
#   pnpm dev:postgres
#   pnpm dev:mysql
#
# To make a non-SQLite dialect the default permanently, comment out
# the SQLite block below and uncomment the Postgres or MySQL block.
#
# Setup:
#   cp .env.example .env
#
# Full env reference: nextly/docs/configuration/environment.mdx
# Schema source of truth: packages/nextly/src/shared/lib/env.ts

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DB_DIALECT picks which adapter Nextly loads at boot. One of:
#   - sqlite      file-backed, no Docker required (the default)
#   - postgresql  needs a running Postgres on the URL below
#                 (or run `pnpm dev:postgres` to auto-start Docker)
#   - mysql       needs a running MySQL on the URL below
#                 (or run `pnpm dev:mysql` to auto-start Docker)
#
# DATABASE_URL must match the chosen DB_DIALECT. The defaults below
# match docker-compose.yml so the dev:postgres / dev:mysql scripts
# work out of the box. Uncomment exactly one block.

# --- SQLite (default) --------------------------------------------------------
DB_DIALECT=sqlite
DATABASE_URL=file:./data/playground.db

# --- PostgreSQL --------------------------------------------------------------
# DB_DIALECT=postgresql
# DATABASE_URL=postgres://postgres:dev_password_change_in_production@localhost:5432/nextly_dev

# --- MySQL -------------------------------------------------------------------
# DB_DIALECT=mysql
# DATABASE_URL=mysql://root:dev_password@localhost:3306/nextly_dev

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret used by Nextly's custom auth to sign JWTs (access + refresh
# tokens, sessions). Required (>= 32 chars) in production. Optional in
# dev, but session tokens won't survive a restart without it. Leave it
# set locally so refresh tokens persist across server reboots.
#
# Generate a real one with:
#   openssl rand -base64 32
NEXTLY_SECRET=playground-dev-secret-do-not-use-in-production-32chars-min

# -----------------------------------------------------------------------------
# Application URL
# -----------------------------------------------------------------------------
# Public-facing URL of the app. Used for email links and CSRF origin
# matching. Required in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Server port
# -----------------------------------------------------------------------------
# The wrapper auto-detects "port in use" and exits with a hint to
# override (e.g. PORT=3001 pnpm dev:app).
PORT=3000

# -----------------------------------------------------------------------------
# Optional - comma-separated extra origins for CSRF validation.
# Most contributors don't need this. The app's own origin
# (NEXT_PUBLIC_APP_URL) is always allowed.
# -----------------------------------------------------------------------------
# NEXTLY_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Optional - SMTP for email features. Leave commented out for the
# playground; the dev auto-login flow bypasses email entirely.
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
