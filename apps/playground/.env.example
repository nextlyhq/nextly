# =============================================================================
# Nextly - Environment Configuration
# =============================================================================
# This file documents all environment variables required when using Nextly
# in your Next.js application.
#
# Nextly is an npm package providing headless CMS functionality with RBAC,
# authentication, and admin UI components for Next.js 16 projects.
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:        cp .env.example .env
#   2. Update DATABASE_URL with your database credentials
#   3. Generate AUTH_SECRET:  openssl rand -base64 32
#   4. Configure storage (Vercel Blob or S3)
#   5. Configure other variables as needed for your project
#
# IMPORTANT: Review security-sensitive values marked with (!) before production
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime Environment
# -----------------------------------------------------------------------------
# Application environment (development | production | test)
# Next.js sets this automatically based on command (`next dev` or `next start`).
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (Required)
# -----------------------------------------------------------------------------
# Database dialect - determines which database driver to use
# Options: postgresql | mysql | sqlite
DB_DIALECT=postgresql

# Database connection URL (REQUIRED)
# PostgreSQL (Recommended for production):
DATABASE_URL=postgresql://postgres:dev_password_change_in_production@localhost:5432/nextly_dev

# MySQL (Alternative):
# DATABASE_URL=mysql://root:root@localhost:3306/nextly_dev

# SQLite (Local development only - not recommended for production):
# DATABASE_URL=file:./dev.db

# Connection Pool Settings
# Maximum number of connections in the pool
DB_POOL_MAX=20

# Minimum number of connections in the pool
DB_POOL_MIN=2

# Connection timeout in milliseconds
DB_CONNECTION_TIMEOUT=30000

# Query timeout in milliseconds
DB_QUERY_TIMEOUT=15000

# Health check interval in milliseconds
DB_HEALTHCHECK_INTERVAL_MS=30000

# Use snake_case for database column names (default: false for camelCase)
DB_SNAKE_CASE=false

# -----------------------------------------------------------------------------
# Authentication (Auth.js v5) - REQUIRED
# -----------------------------------------------------------------------------
# (!) CRITICAL: Secret key for encrypting JWTs and session tokens
# MUST be at least 32 characters in production
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-minimum-32-characters-change-in-production-use-openssl-rand

# Legacy Auth.js v4 compatibility (prefer AUTH_SECRET for v5)
# Only needed if migrating from Auth.js v4
# NEXTAUTH_SECRET=your-legacy-secret-key

# Trust the host header (recommended: true for Next.js deployments)
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Application URLs (Required for Auth.js)
# -----------------------------------------------------------------------------
# Public URL where your application is accessible
# REQUIRED in production for OAuth callbacks and email links
NEXTAUTH_URL=http://localhost:3000

# Internal URL for server-side API calls (usually same as NEXTAUTH_URL)
NEXTAUTH_URL_INTERNAL=http://localhost:3000

# Public-facing application URL (used in client-side code)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL for API routes (default: /api)
API_BASE_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# OAuth Providers (Optional - configure if using social login)
# -----------------------------------------------------------------------------
# Google OAuth
# Get credentials: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth
# Get credentials: https://github.com/settings/developers
# AUTH_GITHUB_ID=your-github-client-id
# AUTH_GITHUB_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# SMTP / Email Configuration (Optional)
# -----------------------------------------------------------------------------
# Required only if you want to send emails (password resets, notifications)
# If any SMTP variable is set in production, ALL must be configured

# SMTP server hostname
# SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
# SMTP_PORT=587

# SMTP authentication username
# SMTP_USER=your-email@gmail.com

# SMTP authentication password (use app-specific password for Gmail)
# SMTP_PASS=your-app-password

# From email address for outgoing emails
# SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Docker Compose Variables (Development Only)
# -----------------------------------------------------------------------------
# These variables are used by docker-compose.yml for local database setup
# Not needed if connecting to existing database

# Database name for Docker PostgreSQL
DB_NAME=nextly_dev

# Database user for Docker PostgreSQL
DB_USER=postgres

# (!) Database password for Docker PostgreSQL (CHANGE IN PRODUCTION!)
DB_PASSWORD=dev_password_change_in_production

# PostgreSQL port (default: 5432)
DB_PORT=5432

# Adminer database UI port (default: 8080)
# Access at: http://localhost:8080
ADMINER_PORT=8080

# Redis cache port (optional, used with docker-compose profile: with-redis)
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Development Tools (Development Only)
# -----------------------------------------------------------------------------
# Drizzle Studio port for database GUI
# Run with: pnpm db:studio
# Access at: http://localhost:4983
DRIZZLE_STUDIO_PORT=4983

# -----------------------------------------------------------------------------
# Permission Caching (Optional - Performance Optimization)
# -----------------------------------------------------------------------------
# Enable hybrid permission caching (in-memory + database)
# Improves performance by reducing permission check queries by ~60%
# Default: true (enabled)
# PERMISSION_CACHE_ENABLED=true

# Time-to-live for database cache entries (in seconds)
# Default: 86400 (24 hours)
# PERMISSION_CACHE_TTL_SECONDS=86400

# In-memory cache size (number of entries)
# Tier 1 LRU cache holds most recently checked permissions
# Default: 10000 entries (~60 seconds TTL)
# PERMISSION_CACHE_MEMORY_SIZE=10000

# Enable cache debugging logs (verbose logging)
# Useful for monitoring cache hit rates and performance
# DEBUG_CACHE=1

# IMPORTANT: Permission Cache Cleanup
# The database permission cache (Tier 2) requires periodic cleanup to remove expired entries.
#
# OPTION 1 - Cron Job (Recommended for production):
#   Set up a daily cron job to call the cleanup API endpoint:
#
#   0 2 * * * curl -X POST http://localhost:3000/api/auth/cache/cleanup
#
#   Or use node-cron in your Next.js application:
#
#   import cron from 'node-cron';
#   import { ServiceContainer } from 'nextly';
#
#   cron.schedule('0 2 * * *', async () => {
#     const container = ServiceContainer.getInstance();
#     const cacheService = container.getCacheService();
#     const deleted = await cacheService.cleanupExpired();
#     console.log(`Cleaned up ${deleted} expired cache entries`);
#   });
#
# OPTION 2 - Database Triggers (PostgreSQL only):
#   Create a PostgreSQL scheduled job using pg_cron extension
#
# OPTION 3 - Manual Cleanup:
#   Run cleanup manually via API or CLI when needed
#
# Cleanup frequency recommendation: Daily (matching the 24h default TTL)

# -----------------------------------------------------------------------------
# Debug & Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable detailed RBAC permission checking logs
# Useful for debugging permission issues
# DEBUG_RBAC=1

# -----------------------------------------------------------------------------
# Storage Configuration (Required)
# -----------------------------------------------------------------------------
# Nextly requires a cloud storage adapter for media uploads.
# Choose one of the following options:
#
# - Vercel Blob: Cloud storage optimized for Vercel deployments (default)
# - S3: AWS S3 or S3-compatible services (R2, MinIO, DigitalOcean Spaces)
#
# Set STORAGE_ADAPTER to choose the active storage backend:
# Options: vercel | s3
STORAGE_ADAPTER=vercel

# ---- Vercel Blob Storage (Recommended for Vercel deployments) ----
# Get your token from: Vercel Dashboard > Storage > Blob > Tokens
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ---- AWS S3 Storage ----
# For standard AWS S3 buckets
# STORAGE_ADAPTER=s3
# S3_BUCKET=my-nextly-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ---- Cloudflare R2 Storage (S3-compatible) ----
# Requires custom endpoint and public URL
# STORAGE_ADAPTER=s3
# S3_BUCKET=my-r2-bucket
# S3_REGION=auto
# AWS_ACCESS_KEY_ID=your-r2-access-key
# AWS_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://pub-xxxx.r2.dev

# ---- MinIO Storage (S3-compatible, self-hosted) ----
# Requires forcePathStyle for MinIO
# STORAGE_ADAPTER=s3
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

# =============================================================================
# End of Configuration
# =============================================================================
#
# NEXT STEPS AFTER SETUP:
#   1. Ensure DATABASE_URL points to your database
#   2. Configure storage (BLOB_READ_WRITE_TOKEN for Vercel or S3 credentials)
#   3. Run database migrations: pnpm db:push
#   4. (Optional) Seed sample data: pnpm db:seed
#   5. Start development server: pnpm dev
#   6. Access admin UI: http://localhost:3000/admin
#
# TROUBLESHOOTING:
#   - Environment validation errors: Check packages/nextly/src/lib/env.ts for requirements
#   - Database connection issues: Verify DATABASE_URL format and credentials
#   - Auth issues: Ensure AUTH_SECRET is at least 32 characters
#   - Storage errors: Verify BLOB_READ_WRITE_TOKEN or S3 credentials are set
#
# PRODUCTION CHECKLIST:
#   (!) Generate strong AUTH_SECRET (min 32 chars): openssl rand -base64 32
#   (!) Use production database URL (not localhost)
#   (!) Set NODE_ENV=production
#   (!) Configure NEXT_PUBLIC_APP_URL to your domain
#   (!) Configure storage credentials (Vercel Blob or S3)
#   (!) Never commit .env file to version control
#   (!) Use environment variables in your deployment platform
#
# =============================================================================
