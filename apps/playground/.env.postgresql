# PostgreSQL Environment Configuration
# Copy this to .env to use PostgreSQL

NODE_ENV=development
DB_DIALECT=postgresql
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/nextly_dev

# Auth Configuration
AUTH_SECRET=your-secret-key-minimum-32-characters-change-in-production-use-openssl-rand
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
