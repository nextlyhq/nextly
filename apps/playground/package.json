{
  "name": "playground",
  "version": "0.1.1",
  "description": "Nextly - Development playground and testing environment",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "nextly dev",
    "start": "next start",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "env:copy": "cp .env.example .env",
    "db:generate": "pnpm --filter @revnixhq/nextly run db:generate",
    "db:push": "pnpm --filter @revnixhq/nextly run db:push",
    "db:seed": "pnpm --filter @revnixhq/nextly run db:seed",
    "db:seed:all": "pnpm --filter @revnixhq/nextly run db:seed:all",
    "db:studio": "pnpm --filter @revnixhq/nextly run db:studio"
  },
  "dependencies": {
    "@revnixhq/plugin-form-builder": "workspace:^",
    "@revnixhq/admin": "workspace:^",
    "@revnixhq/nextly": "workspace:^",
    "@revnixhq/adapter-drizzle": "workspace:^",
    "@revnixhq/adapter-postgres": "workspace:^",
    "@revnixhq/adapter-mysql": "workspace:^",
    "@revnixhq/adapter-sqlite": "workspace:^",
    "@revnixhq/storage-s3": "workspace:^",
    "@revnixhq/storage-vercel-blob": "workspace:^",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "drizzle-orm": "^0.44.5",
    "next": "16.0.0",
    "pg": "^8.16.3",
    "mysql2": "^3.12.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "better-sqlite3": "^12.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
