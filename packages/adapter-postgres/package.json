{
  "name": "@revnixhq/adapter-postgres",
  "version": "0.0.140",
  "description": "PostgreSQL database adapter for Nextly - extends @nextly/adapter-drizzle",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@revnixhq/adapter-drizzle": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@nextly/eslint-config": "workspace:*",
    "@nextly/tsconfig": "workspace:*",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "eslint": "^9.34.0",
    "pg": "^8.13.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.8"
  },
  "keywords": [
    "nextly",
    "postgres",
    "postgresql",
    "database",
    "adapter",
    "drizzle",
    "orm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nextlyhq/nextly",
    "directory": "packages/adapter-postgres"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
