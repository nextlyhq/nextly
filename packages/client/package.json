{
  "name": "@revnixhq/client",
  "version": "0.0.140",
  "description": "Nextly - REST API SDK for browser-based applications",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@nextly/eslint-config": "workspace:*",
    "@nextly/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "eslint": "^9.34.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.8"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.62.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nextlyhq/nextly",
    "directory": "packages/client"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
