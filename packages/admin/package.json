{
  "name": "@revnixhq/admin",
  "version": "0.0.139",
  "description": "Nextly - Admin dashboard and management interface",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./lib/component-registry": {
      "types": "./dist/lib/plugins/component-registry.d.ts",
      "import": "./dist/lib/plugins/component-registry.mjs",
      "default": "./dist/lib/plugins/component-registry.mjs"
    },
    "./lib/plugin-components": {
      "types": "./dist/lib/plugins/plugin-components.d.ts",
      "import": "./dist/lib/plugins/plugin-components.mjs",
      "default": "./dist/lib/plugins/plugin-components.mjs"
    },
    "./style.css": "./dist/styles/globals.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "analyze": "ANALYZE=true pnpm build"
  },
  "bin": {
    "create-admin-app": "dist/cli.cjs"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
