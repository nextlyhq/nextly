{
  "name": "@nextly/telemetry",
  "version": "0.0.1",
  "description": "Internal anonymous telemetry client used by create-nextly-app and the nextly CLI. Not published to npm; bundled into consumers by tsup.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "conf": "^13.1.0",
    "env-paths": "^3.0.0",
    "picocolors": "^1.1.1",
    "posthog-node": "^5.8.0"
  },
  "devDependencies": {
    "@nextly/eslint-config": "workspace:*",
    "@nextly/tsconfig": "workspace:*",
    "@types/node": "^20.19.17",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.34.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
