{
  "name": "@nextlyhq/ui",
  "version": "0.0.2-alpha.37",
  "description": "Nextly UI — Reusable React component library for Nextly plugins and custom admin UIs",
  "license": "MIT",
  "keywords": [
    "nextly",
    "ui",
    "components",
    "react",
    "radix",
    "tailwind"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tailwind-preset": {
      "import": {
        "types": "./dist/tailwind-preset.d.ts",
        "default": "./dist/tailwind-preset.mjs"
      },
      "require": {
        "types": "./dist/tailwind-preset.d.cts",
        "default": "./dist/tailwind-preset.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.mjs"
      },
      "require": {
        "types": "./dist/utils.d.cts",
        "default": "./dist/utils.cjs"
      }
    },
    "./theme.css": "./dist/theme.css",
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsup && tsup --config tsup.server-safe.config.ts && node scripts/check-client-directive.mjs && node scripts/build-css.mjs",
    "build:js": "tsup",
    "build:css": "node scripts/build-css.mjs",
    "dev": "tsup --watch & tsup --config tsup.server-safe.config.ts --watch & wait",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@nextlyhq/eslint-config": "workspace:*",
    "@nextlyhq/tsconfig": "workspace:*",
    "@tailwindcss/cli": "^4.3.2",
    "@types/culori": "^4.0.1",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "culori": "^4.0.2",
    "eslint": "^9.39.1",
    "jsdom": "^27.1.0",
    "lucide-react": "^0.544.0",
    "postcss": "^8.5.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextlyhq/nextly.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "homepage": "https://nextlyhq.com",
  "bugs": {
    "url": "https://github.com/nextlyhq/nextly/issues"
  },
  "author": "Nextly <contact@nextlyhq.com> (https://nextlyhq.com)"
}
