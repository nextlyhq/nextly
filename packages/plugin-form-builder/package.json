{
  "name": "@nextlyhq/plugin-form-builder",
  "version": "0.0.2-alpha.37",
  "description": "Visual form builder plugin for Nextly with Code-First and Schema Builder support",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts src/admin/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react-hook-form": "^7.66.0",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@nextlyhq/admin": "0.0.2-alpha.37",
    "@nextlyhq/plugin-sdk": "workspace:*",
    "@nextlyhq/ui": "workspace:^",
    "@tanstack/react-query": ">=5.0.0",
    "lucide-react": ">=0.400.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "nextly": "0.0.2-alpha.37",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@nextlyhq/admin": "workspace:*",
    "@nextlyhq/plugin-sdk": "workspace:*",
    "@nextlyhq/tsconfig": "workspace:*",
    "@nextlyhq/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@types/node": "^20.19.17",
    "@types/react": "19.2.0",
    "lucide-react": "^0.544.0",
    "nextly": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "nextly",
    "nextly-plugin",
    "plugin",
    "forms",
    "form-builder",
    "cms",
    "headless-cms",
    "app-framework"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextlyhq/nextly.git",
    "directory": "packages/plugin-form-builder"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "homepage": "https://nextlyhq.com",
  "bugs": {
    "url": "https://github.com/nextlyhq/nextly/issues"
  },
  "author": "Nextly <contact@nextlyhq.com> (https://nextlyhq.com)"
}
