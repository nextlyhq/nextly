// What: a fixture that DELIBERATELY violates the F1 PR 1 ESLint rule
// `no-restricted-imports` for drizzle-kit-lazy. Renamed to .disabled so it
// does not load as a normal source file.
// Why: lets us assert the ESLint rule fires by renaming this file back to
// .ts and running lint. The PR description includes the exact verification
// command. Manual step (not an automated test) because TS+ESLint do not
// have a clean way to assert "this file fails lint" in vitest without
// running the ESLint API directly.
//
// To verify the rule fires (the file extension `.fixture.ts` is ignored by
// the default eslint flat-config glob, so we run ESLint directly with
// --no-ignore against the file):
//
//   mv packages/nextly/src/dispatcher/handlers/__tests__/eslint-rule-fires.fixture.ts.disabled \
//      packages/nextly/src/dispatcher/handlers/__tests__/eslint-rule-fires.fixture.ts
//   cd packages/nextly && npx eslint --no-ignore \
//      src/dispatcher/handlers/__tests__/eslint-rule-fires.fixture.ts
//   # Expected: ESLint reports the no-restricted-imports violation on the
//   # import line below with the F1 PR 1 message. Then revert:
//   cd ../.. && \
//   mv packages/nextly/src/dispatcher/handlers/__tests__/eslint-rule-fires.fixture.ts \
//      packages/nextly/src/dispatcher/handlers/__tests__/eslint-rule-fires.fixture.ts.disabled

import { getPgDrizzleKit } from "../../../database/drizzle-kit-lazy";

export function shouldFailEslint(): unknown {
  return getPgDrizzleKit;
}
