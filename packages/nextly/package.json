  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.dts.json && node --max-old-space-size=8192 --import tsx/esm ./node_modules/rollup/dist/bin/rollup -c rollup.dts.config.ts && rimraf dist/_intermediate_dts && node scripts/postbuild.cjs",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "example": "cross-env DATABASE_URL=postgresql://example:example@localhost:5432/example node ./node_modules/tsx/dist/cli.mjs example.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:seed": "tsx scripts/seed-permissions.ts",
    "db:seed:all": "tsx scripts/seed-all.ts",
    "drizzle:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "drizzle:check": "drizzle-kit check --config=drizzle.config.ts",
    "drizzle:pull": "drizzle-kit pull --config=drizzle.config.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
