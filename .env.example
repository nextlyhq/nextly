# ═══════════════════════════════════════════════
# 🗄️  Database Configuration
# ═══════════════════════════════════════════════

# Database dialect (postgresql, mysql, sqlite)
DB_DIALECT=postgresql

# Full database connection URL
# For Docker: postgresql://postgres:postgres@localhost:5432/nextly_dev
# For local PostgreSQL: postgresql://<USER>:<PASSWORD>@localhost:5432/<DB_NAME>
# For production: Use managed database URL (Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>

# Connection pooling (optional - has sensible defaults)
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# DB_CONNECTION_TIMEOUT=30000
# DB_QUERY_TIMEOUT=15000

# ═══════════════════════════════════════════════
# 🪵 Database Logging (Optional)
# ═══════════════════════════════════════════════
DB_LOG_ENABLED=true
DB_LOG_LEVEL=debug

# ═══════════════════════════════════════════════
# 🐳 Docker Development (Optional)
# ═══════════════════════════════════════════════
# For Docker setup, see .env.docker for complete example
# Quick start: pnpm docker:up
