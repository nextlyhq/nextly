# ═══════════════════════════════════════════════
# 🗄️  Database Configuration
# ═══════════════════════════════════════════════

# Database dialect (postgresql, mysql, sqlite)
DB_DIALECT=postgresql

# Full database connection URL
# For Docker: postgresql://postgres:postgres@localhost:5432/nextly_dev
# For local PostgreSQL: postgresql://<USER>:<PASSWORD>@localhost:5432/<DB_NAME>
# For production: Use managed database URL (Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>

# Database pool tuning (applied to the underlying pg.Pool). All four are
# honored by createAdapterFromEnv via packages/nextly/src/database/factory.ts.
# Defaults are sensible for Postgres-on-localhost; cloud providers (Neon,
# Supabase) auto-tune via packages/adapter-postgres/src/provider.ts.
# DB_QUERY_TIMEOUT currently only takes effect for the PostgreSQL dialect;
# MySQL/SQLite adapters do not consume it.
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# DB_POOL_IDLE_TIMEOUT=30000
# DB_QUERY_TIMEOUT=15000

# ═══════════════════════════════════════════════
# 🪵 Database Logging (Optional)
# ═══════════════════════════════════════════════
DB_LOG_ENABLED=true
DB_LOG_LEVEL=debug

# ═══════════════════════════════════════════════
# 🛠️  Code-first schema edits (Optional, dev-only)
# ═══════════════════════════════════════════════
# Opt-in escape hatch: when set to 1, removing fields from a code-first
# collection / single / component definition in your config auto-applies
# the column drops on HMR / boot. Without this flag the drops are gated
# to the admin Schema Builder for explicit confirmation. Mixed drop+add
# (rename ambiguity), drop_table, type changes, and NOT NULL additions
# stay gated regardless. Production never auto-applies — schema changes
# there belong in migrations committed with the code.
# NEXTLY_ALLOW_CODE_FIRST_DROPS=1

# ═══════════════════════════════════════════════
# 🐳 Docker Development (Optional)
# ═══════════════════════════════════════════════
# For Docker setup, see .env.docker for complete example
# Quick start: pnpm docker:up
