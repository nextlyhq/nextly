# pnpm workspace configuration
# Automatically link workspace packages
link-workspace-packages = true

# When publishing, convert workspace:* to actual versions
# This ensures external npm/yarn users can install packages
# Note: This is the default behavior in pnpm, but we're being explicit

# Registry configuration (use npm public registry)
registry = https://registry.npmjs.org/

# Publishing auth: npm Trusted Publishing (OIDC). The release workflow
# exchanges its GitHub OIDC token at publish time, so no _authToken is
# stored here. Local publishes (not supported) would require `npm login`.
@nextlyhq:registry=https://registry.npmjs.org
